# Copy to .env and fill in values

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/cancerprogressionatlas

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# File storage
UPLOAD_DIR=./uploads

# S3-compatible storage (for Railway/production — leave blank for local disk)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
