# Copy to .env and fill in values

# Server
PORT=4000
NODE_ENV=development

# Auth (generate a long random secret for production)
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES=7d

# PostgreSQL (Railway provides this automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/cancerprogressionatlas

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# Admin access — comma-separated list of email addresses that can access /admin
# These accounts must already be registered. Keep this out of version control.
ADMIN_EMAILS=your@email.com

# File storage
UPLOAD_DIR=./uploads

# S3-compatible storage (for Railway/production — leave blank for local disk)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
